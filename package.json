{
  "name": "generic-erp-analytics-mcp-server",
  "version": "1.0.0",
  "description": "Generic read-only MCP analytics gateway for MongoDB-backed ERP systems.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json && node scripts/copy-catalog-assets.mjs",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "dotenv": "^16.4.7",
    "mongodb": "^6.16.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
